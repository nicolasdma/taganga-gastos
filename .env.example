# Convex production URL (Dashboard → Settings → URL & Deploy Key)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Used by Convex Auth OAuth redirects (local dev example)
# VITE_CONVEX_SITE_URL=http://127.0.0.1:3211

# Set on Convex deployment (Dashboard or `npx convex env set`):
# SITE_URL=http://localhost:5173
# AUTH_GOOGLE_ID=...
# AUTH_GOOGLE_SECRET=...
# JWT_PRIVATE_KEY=...
# JWKS=...
